meta {
  name: Get Question Themes
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/admin/question-themes
  body: none
  auth: inherit
}

params:query {
  ~sort-by: createdAt
  ~sort-order: desc
  ~limit: 50
  ~status: active
}

settings {
  encodeUrl: true
  timeout: inherit
  followRedirects: true
  maxRedirects: 5
}
