meta {
  name: Get Questions
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/admin/questions
  body: none
  auth: inherit
}

params:query {
  ~sort-by: createdAt
  ~sort-order: desc
  ~status: active
  ~category: trivia
  ~cognitive-difficulty: easy
  ~author-role: admin
  ~theme-ids: 507f1f77bcf86cd799439011
}

settings {
  encodeUrl: true
  timeout: inherit
  followRedirects: true
  maxRedirects: 5
}
