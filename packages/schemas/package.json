{
  "name": "@goat-it/schemas",
  "type": "module",
  "version": "0.0.19",
  "description": "Shared types, constants and Zod schemas for the Goat It projects.",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && pnpm run check:dts",
    "typecheck": "tsc --noEmit",
    "check:dts": "! grep -rn ': any' dist/ --include='*.d.mts'",
    "prepublishOnly": "pnpm run build"
  },
  "author": "Antoine ZANARDI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antoinezanardi/goat-it-api",
    "directory": "packages/schemas"
  },
  "packageManager": "pnpm@11.17.0",
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "tsdown": "^0.22.13",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@faker-js/faker": ">=10.5.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./question": {
      "types": "./dist/question/index.d.mts",
      "import": "./dist/question/index.mjs"
    },
    "./question-theme": {
      "types": "./dist/question-theme/index.d.mts",
      "import": "./dist/question-theme/index.mjs"
    },
    "./shared/locale": {
      "types": "./dist/shared/locale/index.d.mts",
      "import": "./dist/shared/locale/index.mjs"
    },
    "./shared/error": {
      "types": "./dist/shared/error/index.d.mts",
      "import": "./dist/shared/error/index.mjs"
    },
    "./shared/constants": {
      "types": "./dist/shared/constants/index.d.mts",
      "import": "./dist/shared/constants/index.mjs"
    },
    "./testing/question": {
      "types": "./dist/testing/question/index.d.mts",
      "import": "./dist/testing/question/index.mjs"
    },
    "./testing/question-theme": {
      "types": "./dist/testing/question-theme/index.d.mts",
      "import": "./dist/testing/question-theme/index.mjs"
    },
    "./testing/shared": {
      "types": "./dist/testing/shared/index.d.mts",
      "import": "./dist/testing/shared/index.mjs"
    }
  },
  "dependencies": {
    "type-fest": "^5.8.0"
  },
  "sideEffects": false
}
