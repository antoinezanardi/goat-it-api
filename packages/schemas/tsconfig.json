{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@question/*": ["../../src/contexts/question/*"],
      "@question-theme/*": ["../../src/contexts/question-theme/*"],
      "@shared/*": ["../../src/shared/*"]
    }
  },
  "include": ["src", "tsdown.config.ts"]
}
